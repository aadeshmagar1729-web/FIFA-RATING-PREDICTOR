{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Install deps",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Backend: Migrate DB",
      "type": "shell",
      "command": "python manage.py migrate",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Backend: Run Server",
      "type": "shell",
      "command": "python manage.py runserver",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Install deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Run Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Full Stack (Backend + Frontend)",
      "dependsOn": ["Backend: Run Server", "Frontend: Run Dev Server"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
